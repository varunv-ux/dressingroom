{
  "manifest_version": 3,
  "name": "Dressing Room",
  "short_name": "Dressing Room",
  "version": "0.2.1",
  "description": "Create AI try-ons on shopping pages and save your favorite looks.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "unlimitedStorage"],
  "host_permissions": ["https://dressingroom-gray.vercel.app/*"],
  "content_scripts": [
    {
      "matches": [
        "*://*.zara.com/*",
        "*://*.mango.com/*",
        "*://*.suitsupply.com/*",
        "*://*.anthropologie.com/*",
        "*://*.hm.com/*",
        "*://*.uniqlo.com/*",
        "*://*.nordstrom.com/*",
        "*://*.jcrew.com/*",
        "*://*.asos.com/*",
        "*://*.everlane.com/*",
        "*://*.ssense.com/*",
        "*://*.farfetch.com/*",
        "*://*.net-a-porter.com/*",
        "*://*.mrporter.com/*",
        "*://*.cos.com/*",
        "*://*.arket.com/*",
        "*://*.aritzia.com/*",
        "*://*.urbanoutfitters.com/*",
        "*://*.gap.com/*",
        "*://*.bananarepublic.com/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Dressing Room",
    "default_popup": "popup.html"
  }
}
