{
  "manifest_version": 3,
  "name": "Dressing Room",
  "short_name": "Dressing Room",
  "version": "0.2.1",
  "description": "Create AI try-ons on shopping pages and save your favorite looks.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "unlimitedStorage"],
  "host_permissions": ["https://dressingroom-gray.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Dressing Room",
    "default_popup": "popup.html"
  }
}
